{
  "functions": {
    "api/image/enhance.ts": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/order/create-razorpay-order", "destination": "/api/payments/order/create-razorpay-order" },
    { "source": "/api/order/confirm-order", "destination": "/api/payments/order/confirm-order" },
    { "source": "/api/payment/verify-razorpay-payment", "destination": "/api/payments/verify-razorpay-payment" },
    { "source": "/api/subscription/create-razorpay-order", "destination": "/api/payments/subscription/create-razorpay-order" },
    { "source": "/api/subscription/confirm-subscription", "destination": "/api/payments/subscription/confirm-subscription" },
    { "source": "/api/subscription/create-plus-order", "destination": "/api/payments/subscription/create-plus-order" },
    { "source": "/api/subscription/confirm-plus-payment", "destination": "/api/payments/subscription/confirm-plus-payment" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/keepalive",                            "schedule": "0 12 * * *" },
    { "path": "/api/subscription/daily-digest",      "schedule": "35 11 * * *" },
    { "path": "/api/subscription/auto-deliver?slot=08-09", "schedule": "0 4 * * *"  },
    { "path": "/api/subscription/auto-deliver?slot=12-14", "schedule": "0 9 * * *"  },
    { "path": "/api/subscription/auto-deliver?slot=19-21", "schedule": "0 16 * * *" }
  ]
}
