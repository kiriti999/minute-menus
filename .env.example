# ─────────────────────────────────────────────
# Minute Menus — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Google Gemini ──────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Site URL ───────────────────────────────────
# Production URL for QR codes and OAuth redirects
VITE_SITE_URL=https://minutemenus.com

# ── Supabase ───────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Payment Providers ──────────────────────────
# Razorpay (India) — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Clover (US/CA) — https://www.clover.com/developers
CLOVER_API_KEY=
CLOVER_MERCHANT_ID=

# ── Supabase Service Role (server-side API routes only — never expose client-side) ──
# Find in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── Internal API Secret ───────────────────────────────
# Shared secret used to authenticate browser → /api/subscription/cancel-order calls.
# Set the same value in both VITE_INTERNAL_API_SECRET (browser) and
# INTERNAL_API_SECRET (server/Vercel env). Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=
VITE_INTERNAL_API_SECRET=

# ── Local development (pnpm dev only — ignored in production builds) ──
# Skip owner login page and open Menu Editor on load
VITE_DEV_SKIP_LOGIN=false
# Auto-open customer menu at this slug when visiting http://localhost:5173/
# VITE_DEV_MENU_SLUG=fresh-and-fusion

# ── Email (Microsoft Outlook SMTP) ───────────────────────────────────────────
# Single verified platform sender — no daily cap on paid Microsoft 365.
# If 2FA is enabled, generate an App Password:
# https://account.microsoft.com/security → Advanced security → App passwords
SMTP_USER=minutemenus@outlook.com
SMTP_PASS=
