# ─────────────────────────────────────────────
# Minute Menus — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Google Gemini ──────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Site URL ───────────────────────────────────
# Production URL for QR codes and OAuth redirects
VITE_SITE_URL=https://minutemenus.com

# ── Supabase ───────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Payment Providers ──────────────────────────
# Razorpay (India) — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Clover (US/CA) — https://www.clover.com/developers
CLOVER_API_KEY=
CLOVER_MERCHANT_ID=

# ── Email (Resend) ─────────────────────────────────────
# Used by /api/sold-out-email to notify owners when a dish sells out.
# Add via Vercel Marketplace (auto-wires RESEND_API_KEY) or manually:
#   https://resend.com/api-keys
RESEND_API_KEY=
# Sender address — must be from a domain verified in your Resend account.
# For testing, Resend allows onboarding@resend.dev as the from address.
FROM_EMAIL=notifications@minutemenus.com
